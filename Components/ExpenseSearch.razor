@using MongoDB.Bson
@using finance.Models
@using finance.Models.Tables

<div class="m-2">
    <div class="relative w-1/2 m-2">
        <input type="text" class="w-full pl-10 pr-3 py-2 text-white rounded-lg bg-dark-700 border border-dark-800"
               placeholder="Search" @oninput="OnSearch" />
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
             class="absolute left-3 top-1/2 -translate-y-1/2 size-5 text-white">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
    </div>
    @foreach (var expense in expenses)
    {
        <div class="flex flex-row justify-between items-center  m-2 bg-dark-700 rounded-lg p-2">

            <div class="flex justify-start items-center w-full m-5">
                <p class="text-white text-bold mx-2">@expense.ExpenseName</p>
                <p class="text-white bg-dark-800 p-2 mx-2 rounded-lg text-bold">@expense.Gategory</p>
                <p class="text-white mx-2">@expense.Amount€</p>
            </div>

            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                 class="text-red-500 size-8">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>

        </div>

    }
</div>

@code {
    [Parameter]
    public string UserId { get; set; } = "";

    private ObjectId userObjectId;
    private string search = "";
    private List<Expense> expenses = [];
    private Timer? debounce;

    protected override async Task OnInitializedAsync()
    {
        userObjectId = ObjectId.Parse(UserId);
        await LoadExpenses();
    }

    private void OnSearch(ChangeEventArgs e)
    {
        search = e.Value?.ToString() ?? "";
        debounce?.Dispose();
        debounce = new Timer(async _ =>
        {
            await LoadExpenses();
            await InvokeAsync(StateHasChanged);
        }, null, 300, Timeout.Infinite);
    }

    private async Task LoadExpenses()
    => expenses = await DatabaseManipulator.GetMany<Expense>(e =>
    e.UserId == userObjectId &&
    (string.IsNullOrEmpty(search) || e.ExpenseName.Contains(search)));

    public void Dispose() => debounce?.Dispose();
}
