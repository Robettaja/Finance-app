@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - finance</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body class="w-full bg-dark-950 min-h-screen flex">

    <header class="lg:sticky lg:top-0 lg:min-h-screen lg:w-fit w-0">
        <nav id="navigation" class="hidden data-active:flex lg:flex fixed lg:sticky top-0 left-0 bg-dark-900 w-64 lg:w-fit h-screen flex-col space-y-1 border border-dark-800 z-50">
            <div class="flex justify-end lg:hidden m-2" onclick="toggleNav()">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="text-white size-10">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
            </div>
            <a asp-action="Index" asp-controller="Home" class="text-white cursor-pointer text-xl font-bold m-2">Finance app</a>
            <div class="flex flex-col justify-between flex-1 m-2">
                <div>
                    @if(User.Identity!.IsAuthenticated) {
                        <a asp-action="Index" asp-controller="Home"
                            class="flex items-center hover:bg-dark-800 w-full m-1 @(controller == "Home" && action == "Index" ? "bg-dark-800" : "") rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="text-white size-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                            </svg>
                            <p class="text-white text-lg p-2">Home</p>
                        </a>
                        <a asp-action="Expense" asp-controller="Economy" class="flex items-center hover:bg-dark-800 w-full m-1 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="text-white size-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" />
                            </svg>
                            <p class="text-white text-lg p-2">Expenses</p>
                        </a>
                        <a asp-action="Income" asp-controller="Economy" class="flex items-center hover:bg-dark-800 w-full m-1 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="text-white size-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
                            </svg>
                            <p class="text-white text-lg p-2">Incomes</p>
                        </a>
                    }
                </div>
                <div class="flex m-1">
                    @if(!User.Identity.IsAuthenticated) {
                        <a asp-action="account" asp-controller="Auth" class="bg-dark-800 hover:bg-dark-700 text-white rounded-lg w-fit p-2 m-1 text-sm">Login</a>
                        <a asp-action="account" asp-controller="Auth" asp-route-tab="register" class="bg-dark-50 hover:bg-dark-200 text-dark-600 rounded-lg w-fit p-2 m-1 text-sm">Sign Up</a>
                    } else {
                        <form asp-controller="Auth" asp-action="logout" method="post">
                            <button type="submit" class="text-white rounded-lg bg-dark-800 hover:bg-dark-700 p-3 m-1">Logout</button>
                        </form>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-1 flex">
        <div class="flex flex-col flex-1">
            <svg id="menu" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="text-white sticky top-0 bg-dark-900 text-left data-active:hidden size-15 lg:hidden" onclick="toggleNav()">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
            @RenderBody()
        </div>
    </main>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="path/to/chartjs/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js" integrity="sha384-/TgkGk7p307TH7EXJDuUlgG3Ce1UVolAOFopFekQkkXihi5u/6OCvVKyz1W+idaz" crossorigin="anonymous"></script>
    <script src="_framework/blazor.server.js"></script>
    <script>
        function toggleNav() {
            const navMenu = document.getElementById('navigation')
            const menuBtn = document.getElementById('menu')
            const isActive = navMenu.hasAttribute('data-active')

            if (isActive) {
                navMenu.removeAttribute('data-active')
                menuBtn.removeAttribute('data-active')
            } else {
                navMenu.setAttribute('data-active', '')
                menuBtn.setAttribute('data-active', '')
            }
        }

        document.addEventListener('click', function(event) {
            const navMenu = document.getElementById('navigation')
            const menuBtn = document.getElementById('menu')

            if (!navMenu.contains(event.target) && !menuBtn.contains(event.target)) {
                navMenu.removeAttribute('data-active')
                menuBtn.removeAttribute('data-active')
            }
        })
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
