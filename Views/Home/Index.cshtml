@{
    ViewData["Title"] = "Home Page";
}
@if(!User.Identity!.IsAuthenticated) {
    <div class="flex-1 bg-[url('/images/darkbg.jpg')] bg-center flex items-center justify-center">
        <div class="bg-dark-900/90 p-5 rounded-lg border border-dark-700">
            <a asp-action="account" asp-controller="Auth" class="bg-dark-800 hover:bg-dark-700 text-white rounded-lg w-fit p-2 m-1 text-xl font-medium" >Login</a>
            <a asp-action="account" asp-controller="Auth" asp-route-tab="register" class="bg-dark-50 hover:bg-dark-200 text-dark-600 rounded-lg w-fit p-2 m-1 text-xl font-medium" >Sign Up</a>
        </div>
    </div>
}

else {

    @model HomeViewModel 
<div class="flex flex-col lg:flex-row justify justify-around ">

    <div>
        <div class="m-2 bg-dark-900 rounded-lg h-fit w-full max-w-[1000px] space-y-4 border border-dark-800 m-2">
            <h1 class="text-white font-bold p-2 text-xl">Your Data</h1>
        </div>
        <div class="m-2 bg-dark-900 rounded-lg h-fit w-full max-w-[1000px] space-y-4 border border-dark-800">
            <h1 class="text-white font-bold p-2">Your Saving goal</h1>

            <form class="m-2 space-y-2 space-x-2 flex flex-col" asp-action="Index" asp-controller="Home" method="post">
                <div class="flex flex-row space-x-3 items-center justify-between lg:flex-row">
                    <input class="rounded-lg p-3  w-[100px] my-2 text-white border-hidden bg-dark-800" value="@Model.SavingGoal" name="savingGoal">
                    <p class="text-white bg-dark-800 px-3  rounded-xl p-2  w-fit">Daily Expense limit for goal: @(Model.SavingGoalDaily >= 0 ?Model.SavingGoalDaily.ToString("0.00") + "€" : "Not realistic" )</p>
                </div>
                <button type="submit" class="rounded-xl bg-blue-600 hover:bg-blue-500 text-white mt-4 p-2 p-1 text-lg cursor-pointer w-[170px]">Save</button>
            </form>
        </div>


        <div class="m-2 bg-dark-900 rounded-lg h-fit w-full max-w-[1000px] space-y-4 border border-dark-800">
            <div class="p-2 space-y-2">
                <h2 class="text-white">Information</h2>
                <div class="flex items-center">
                    <p class="text-white">Your savings are:</p>

                    <p class="@(Model.Savings >= 0 ? "text-green-500" : "text-red-500") text-green-500 bg-dark-800 px-3 mx-2 rounded-xl py-2 font-bold">@Model.Savings.ToString("0.00")€</p>
                </div>

                <div class="flex items-center">
                    <p class="text-white">Days until next payday:</p>
                    <p class="text-white bg-dark-800 px-3 mx-2 rounded-xl py-2 font-bold">@(Model.TimeToPayday) Days</p>
                </div>
                <div class="flex items-center">
                    <p class="text-white">Your average expenses cost are:</p>
                    <p class="text-white bg-dark-800 px-3 mx-2 rounded-xl py-2 font-bold">@Model.AverageCostDaily.ToString("0.00")€</p>
                </div>
            </div>
        </div>
    </div>

    <div class="m-2 bg-dark-900 rounded-lg  w-[380px] lg:w-full  max-w-[1000px] space-y-4 border m-2 border-dark-800">

        <div class="h-full w-full">
        <canvas id="myChart"></canvas>
        </div>
    </div>
</div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
    const ctx = document.getElementById('myChart');
    const expenseData = @(Json.Serialize(Model.ExpenseMonthlies.Data));
    const expenseLabels = @(Json.Serialize(Model.ExpenseMonthlies.Labels));

 const myChart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: expenseLabels,
        datasets: [{
          label: 'Expense History',
          data: expenseData,
          borderWidth: 2,
          tension: 0.3, 
          fill: false
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: {
            display: true
          }
        },
        scales: {
          y: {
            beginAtZero: true
          }
        }
      }
    });
    </script>


}
