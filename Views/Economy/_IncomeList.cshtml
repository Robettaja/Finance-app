@model List<finance.Models.Tables.Income>

@foreach (var income in Model)
{
    <div class="flex flex-row justify-between items-center m-2 bg-dark-700 rounded-lg p-1">
        <div class="flex flex-col w-full m-1 space-y-2">
            <div class="flex items-center justify-start">
                <p class="text-white font-bold">@income.IncomeName</p>
                <p class="text-white mx-2 font-bold">@income.Amount€</p>
            </div>
            <div class="flex items-center">
                <p class="text-white">Date:</p>
                <p class="text-white bg-dark-800 px-3 mx-2 rounded-xl py-2 font-bold">@(income.Payday?.ToString("dd.MM.yyyy"))</p>
            </div>
        </div>
        <form>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
             stroke="currentColor" class="text-red-500 size-8 cursor-pointer"
             hx-get="/Expense/DeleteConfirm?id=@income.Id.ToString()&url=/Economy/DeleteIncome"
             hx-target="#confirm-modal"
             hx-swap="innerHTML">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
        </svg>
        </form>
    </div>
<div id="confirm-modal"></div>
}
